// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOKTER
  PERAWAT
  BIDAN
  AHLI_GIZI
  APOTEKER
  FISIOTERAPIS
  ADMIN
}

model User {
  id             String  @id @default(cuid())
  name           String
  username       String  @unique
  password       String
  role           Role
  specialization String?
  sip            String? @unique
  phone          String?

  cpptEntries   Cppt[]          @relation("AuthorRelation")
  verifiedCppts Cppt[]          @relation("VerifierRelation")
  resumes       MedicalResume[]
  patients      Patient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Patient {
  id                  String   @id @default(cuid())
  medicalRecordNumber String   @unique
  name                String
  birthDate           DateTime
  gender              String
  address             String?
  phone               String?

  doctorId   String?
  doctor     User?    @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  // Comprehensive Initial Assessment Fields
  // Anamnesis (Data Subjektif)
  chiefComplaint           String?
  painScale               String?
  currentIllnessHistory   String?
  pastMedicalHistory      String?
  allergies               String?

  // Pemeriksaan Fisik (Data Objektif)
  bloodPressure           String?
  temperature             String?
  pulse                   String?
  respiration             String?
  spO2                    String?
  headToToeExam           String?

  // Skrining Fungsional & Risiko
  fallRisk                String?
  nutritionalStatus       String?
  functionalAssessment    String?

  // Asesmen Medis & Keperawatan
  initialDiagnosis        String?
  nursingPlanning         String?
  doctorNotes             String?

  // Tambahan Spesifik
  patientEducation        String?
  communicationNeeds      String?
  socioeconomicHistory    String?

  // Triage
  triageCategory          String?

  visits      Visit[]
  cpptEntries Cppt[]
  resumes     MedicalResume[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visit {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  checkInAt  DateTime  @default(now())
  checkOutAt DateTime?
  status     String

  cpptEntries   Cppt[]
}

model Cppt {
  id        String  @id @default(cuid())

  visitId   String?
  visit     Visit?   @relation(fields: [visitId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("AuthorRelation", fields: [authorId], references: [id], onDelete: Restrict)

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  subjective  String
  objective   String
  assessment  String
  plan        String
  instruction String?

  isVerified   Boolean   @default(false)
  verifiedById String?
  verifiedBy   User?     @relation("VerifierRelation", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MedicalResume {
  id        String   @id @default(cuid())

  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  diagnosis       String
  mainComplaint   String?
  treatmentPlan   String?
  recommendations String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
